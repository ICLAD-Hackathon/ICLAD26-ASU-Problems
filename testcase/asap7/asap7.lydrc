m9_nonrect_short_e.output("M9.L.1", "M9.L.1 : Minimum feature length of M9 is 40 nm.")


###   V8
((v8.edges.without_length(40.nm) &amp; v8.edges.without_length(120.nm)).extended(1.nm, 1.nm, 1.nm, 1.nm).merged + v8.with_area(0.0144)).output("V8.W.1", "V8.W.1 : Exact width of a V8 instance is [40 nm x 40 nm | 40 nm x 120 nm | 120 nm x 40 nm].")
v8.space(57.nm, euclidian).output("V8.S.1", "V8.S.1 : Minimum spacing between two V8 instances is 57 nm.")
v8.space(57.nm, euclidian).polygons.not_interacting(v8.space(57.nm, projection).polygons).output("V8.S.2", "V8.S.2 : Minimum corner-to-corner spacing between V8 instances is 57 nm.")
v8.inside(m8).interacting(v8 - m8.sized(-20.nm, 0)).interacting(v8 - m8.sized(0, -20.nm)).output("V8.M8.EN.1", "V8.M8.EN.1 : Minimum enclosure of V8 by M8 on at least two opposite sides is 20 nm.")
v8.inside(m9).interacting(v8 - m9.sized(-20.nm, 0)).interacting(v8 - m9.sized(0, -20.nm)).output("V8.M9.EN.2", "V8.M9.EN.2 : Minimum enclosure of V8 by M9 on at least two opposite sides is 20 nm.")
v8.not_inside(m8 &amp; m9).output("V8.AUX.1", "V8.AUX.1 : V8 must be inside M8 and M9.")

###   V9
((v9.edges.without_length(40.nm) &amp; v9.edges.without_length(120.nm)).extended(1.nm, 1.nm, 1.nm, 1.nm).merged + v9.with_area(0.0144)).output("V9.W.1", "V9.W.1 : Exact width of a V9 instance is [40 nm x 40 nm | 40 nm x 120 nm | 120 nm x 40 nm].")
v9.space(57.nm, euclidian).output("V9.S.1", "V9.S.1 : Minimum spacing between two V9 instances is 57 nm.")
v9.space(57.nm, euclidian).polygons.not_interacting(v9.space(57.nm, projection).polygons).output("V9.S.2", "V9.S.2 : Minimum corner-to-corner spacing between V9 instances is 57 nm.")
v9.inside(m9).interacting(v9 - m9.sized(-20.nm, 0)).interacting(v9 - m9.sized(0, -20.nm)).output("V9.M9.EN.1", "V9.M9.EN.1 : Minimum enclosure of V9 by M9 on at least two opposite sides is 20 nm.")
v9.interacting(v9 - pad.sized(-20.nm, 0)).interacting(v9 - pad.sized(0, -20.nm)).output("V9.PAD.EN.2", "V9.PAD.EN.2 : Minimum enclosure of V9 by PAD on at least two opposite sides is 20 nm.")
v9.not_inside(m9 &amp; pad).output("V9.AUX.1", "V9.AUX.1 : V9 must be inside M9 and PAD.")


#   ONGRID  defined in the paper :
#   "ASAP7 : A 7-nm finFET predictive process design kit"
##########################################################
if OFFGRID
info("GRID section")

# special grids for M4.to M7
m4.merged.ongrid(1.dbu, 24.nm).output("M4.AUX.1", "M4.AUX.1 : M4 horizontal edges must be at a grid of 24 nm.")
m5.merged.ongrid(24.nm, 1.dbu).output("M5.AUX.1", "M5.AUX.1 : M5 vertical edges must be at a grid of 24 nm.")
m6.merged.ongrid(1.dbu, 32.nm).output("M6.AUX.1", "M6.AUX.1 : M6 horizontal edges must be at a grid of 32 nm.")
m7.merged.ongrid(32.nm, 1.dbu).output("M7.AUX.1", "M7.AUX.1 : M7 vertical edges must be at a grid of 32 nm.")

all_drawing = [ :nwell, :fin, :gate, :gcut, :active, :sdt, :nselect, :pselect, :slvt, :lvt, :sramdrc, :sramvt, :dummy, :lig, :lisd, :v0, :m1, :v1, :m2, :v2, :m3, :v3, :m4, :v4, :m5, :v5, :m6, :v6, :m7, :v7, :m8, :v8, :m9, :v9, ]
  all_drawing.each do |dwg|
    layer = binding.local_variable_get(dwg)
    nonortho_edges = layer.edges.with_angle(1..89) + layer.edges.with_angle(91..179) + layer.edges.with_angle(-179..-91) + layer.edges.with_angle(-89..-1)
    nonortho_edges.output("#{dwg}.GEOMETRY.NONORTHOGONAL" , "GEOMETRY.NONORTHOGONAL on layer #{dwg}")
  end
end
</text>
</klayout-macro>
