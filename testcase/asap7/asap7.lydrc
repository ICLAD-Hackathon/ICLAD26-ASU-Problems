v7.space(45.nm, euclidian).polygons.not_interacting(v7_s2_proj).output("V7.S.3", "V7.S.3 : Minimum corner-to-corner spacing between two V7 instances is 45 nm.")
v7.inside(m7).interacting(v7 - m7.sized(-11.nm, 0)).interacting(v7 - m7.sized(0, -11.nm)).output("V7.M7.EN.1", "V7.M7.EN.1 : Minimum enclosure of V7 by M7 on at least two opposite sides is 11 nm.")
v7.inside(m8).interacting(v7 - m8.sized(-11.nm, 0)).interacting(v7 - m8.sized(0, -11.nm)).output("V7.M8.EN.2", "V7.M8.EN.2 : Minimum enclosure of V7 by M8 on two opposite sides is 11 nm.")
