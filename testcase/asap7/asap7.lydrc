(v7_aux2_out + v7_aux2_in - v7_aux2_ok).merged.output("V7.M8.AUX.2", "V7.M8.AUX.2 : V7 must exactly be the same width as M8 along the direction perpendicular to the M8 length.")


###   M8
m8.width(40.nm).output("M8.W.1", "M8.W.1 : Minimum width of M8 is 40 nm.")
m8.interacting(m8.edges.with_length(400.nm..1200.nm)).not_interacting(m8.edges.with_length(1200.nm..100.mm)).width(60.nm).output("M8.W.2", "M8.W.2 : Minimum width of M8, when its length &gt;= 400 nm and &lt; 1200 nm, is 60 nm.")
m8.interacting(m8.edges.with_length(1200.nm..1800.nm)).width(80.nm).output("M8.W.3", "M8.W.3 : Minimum width of M8, when its length &gt;= 1200 nm and &lt; 1800 nm, is 80 nm.")
m8.interacting(m8.edges.with_length(1800.nm..100.mm)).width(120.nm).output("M8.W.4", "M8.W.4 : Minimum width of M8, when its length &gt;= 1800 nm, is 120 nm.")
m8.interacting(m8.sized(-1000.nm, 0).sized(1000.nm, 0)).output("M8.W.5", "M8.W.5 : Maximum width of M8 is 2000 nm.")
m8.interacting(m8.sized(0, -1000.nm).sized(0, 1000.nm)).output("M8.W.5", "M8.W.5 : Maximum width of M8 is 2000 nm.")
m8_side_e = m8.edges.with_length(80.nm..100.mm)
m8_tip_e = m8.edges.with_length(0...80.nm)
m8_side_e.space(40.nm, projection).output("M8.S.1", "M8.S.1 : Minimum (side-to-side) spacing between two M8 layer polygons' edges, when both edges are &gt;= 80 nm, is 40 nm.")
m8_tip_e.separation(m8_side_e, 43.nm, projection).output("M8.S.2", "M8.S.2 : Minimum (tip-to-side) spacing between two M8 layer polygons' edges, when one of the edges is &lt; 80 nm and the other is &gt;= 80 nm, is 43 nm.")
m8_tip_e.space(46.nm, projection).output("M8.S.3", "M8.S.3 : Minimum (tip-to-tip) spacing between two M8 layer polygons' edges, when both edges are &lt; 80 nm, is 46 nm.")
m8_ww60 = m8.sized(-(30.nm - 1.dbu)).sized(30.nm - 1.dbu)
m8_ww80 = m8.sized(-(40.nm - 1.dbu)).sized(40.nm - 1.dbu)
m8_ww120 = m8.sized(-(60.nm - 1.dbu)).sized(60.nm - 1.dbu)
m8_ww500 = m8.sized(-(250.nm - 1.dbu)).sized(250.nm - 1.dbu)
m8_ww1000 = m8.sized(-(500.nm - 1.dbu)).sized(500.nm - 1.dbu)
m8_w60_80 = m8.interacting(m8_ww60).not_interacting(m8_ww80)
m8_w80_120 = m8.interacting(m8_ww80).not_interacting(m8_ww120)
m8_w120_500 = m8.interacting(m8_ww120).not_interacting(m8_ww500)
m8_w500_1000 = m8.interacting(m8_ww500).not_interacting(m8_ww1000)
m8_w1000 = m8.interacting(m8_ww1000)
m8_all_e = m8.edges
m8_w60_80.edges.separation(m8_all_e, 60.nm, projection).output("M8.S.4", "M8.S.4 : Minimum spacing between two M8 layer polygons, when the minimum width of one polygon is &gt;= 60 nm and &lt; 80 nm, is 60 nm.")
m8_w80_120.edges.separation(m8_all_e, 80.nm, projection).output("M8.S.5", "M8.S.5 : Minimum spacing between two M8 layer polygons, when the minimum width of one polygon is &gt;= 80 nm and &lt; 120 nm, is 80 nm.")
m8_w120_500.edges.separation(m8_all_e, 120.nm, projection).output("M8.S.6", "M8.S.6 : Minimum spacing between two M8 layer polygons, when the minimum width of one polygon is &gt;= 120 nm and &lt; 500 nm, is 120 nm.")
m8_w500_1000.edges.separation(m8_all_e, 500.nm, projection).output("M8.S.7", "M8.S.7 : Minimum spacing between two M8 layer polygons, when the minimum width of one polygon is &gt;= 500 nm and &lt; 1000 nm, is 500 nm.")
m8_w1000.edges.separation(m8_all_e, 1000.nm, projection).output("M8.S.8", "M8.S.8 : Minimum spacing between two M8 layer polygons, when the minimum width of one polygon is &gt;= 1000 nm, is 1000 nm.")
m8.with_area(0 .. 0.007520).output("M8.A.1", "M8.A.1 : Minimum area of M8 is 7520 nm-sq.")
m8_nonrect_short_e = m8.edges.without_length(40.nm..100.mm).interacting(m8.corners(1..180).sized(1.nm))
m8_nonrect_short_e.output("M8.L.1", "M8.L.1 : Minimum feature length of M8 is 40 nm.")

###   M9
m9.width(40.nm).output("M9.W.1", "M9.W.1 : Minimum width of M9 is 40 nm.")
m9.interacting(m9.edges.with_length(400.nm..1200.nm)).not_interacting(m9.edges.with_length(1200.nm..100.mm)).width(60.nm).output("M9.W.2", "M9.W.2 : Minimum width of M9, when its length &gt;= 400 nm and &lt; 1200 nm, is 60 nm.")
