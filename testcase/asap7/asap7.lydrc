m9_tip_e.space(46.nm, projection).output("M9.S.3", "M9.S.3 : Minimum (tip-to-tip) spacing between two M9 layer polygons' edges, when both edges are &lt; 80 nm, is 46 nm.")
m9_ww60 = m9.sized(-(30.nm - 1.dbu)).sized(30.nm - 1.dbu)
