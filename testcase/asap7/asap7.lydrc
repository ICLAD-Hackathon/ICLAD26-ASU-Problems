m9_w1000 = m9.interacting(m9_ww1000)
m9_all_e = m9.edges
m9_w60_80.edges.separation(m9_all_e, 60.nm, projection).output("M9.S.4", "M9.S.4 : Minimum spacing between two M9 layer polygons, when the minimum width of one polygon is &gt;= 60 nm and &lt; 80 nm, is 60 nm.")
m9_w80_120.edges.separation(m9_all_e, 80.nm, projection).output("M9.S.5", "M9.S.5 : Minimum spacing between two M9 layer polygons, when the minimum width of one polygon is &gt;= 80 nm and &lt; 120 nm, is 80 nm.")
m9_w120_500.edges.separation(m9_all_e, 120.nm, projection).output("M9.S.6", "M9.S.6 : Minimum spacing between two M9 layer polygons, when the minimum width of one polygon is &gt;= 120 nm and &lt; 500 nm, is 120 nm.")
m9_w500_1000.edges.separation(m9_all_e, 500.nm, projection).output("M9.S.7", "M9.S.7 : Minimum spacing between two M9 layer polygons, when the minimum width of one polygon is &gt;= 500 nm and &lt; 1000 nm, is 500 nm.")
m9_w1000.edges.separation(m9_all_e, 1000.nm, projection).output("M9.S.8", "M9.S.8 : Minimum spacing between two M9 layer polygons, when the minimum width of one polygon is &gt;= 1000 nm, is 1000 nm.")
m9.with_area(0 .. 0.007520).output("M9.A.1", "M9.A.1 : Minimum area of M9 is 7520 nm-sq.")
